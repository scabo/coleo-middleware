{
    "name": "scabo/coleo-middleware",
    "description": "PHP Middleware Dispatcher",
    "type": "library",
    "license": "MIT",
    "version": "0.0.1",
    "authors": [
        {
            "name": "Sergey Shevyakov",
            "email": "scabo.dev@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Coleo\\Middleware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ColeoTest\\Middleware\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.2",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "*"
    },
    "scripts": {
        "test": "vendor/bin/phpunit  --display-warnings",
        "inspect": "vendor/bin/phpstan analyse",
        "style_check": "vendor/bin/phpcs",
        "style_fix": "vendor/bin/phpcbf",
        "doc": "php phpDocumentor.phar"
    }
}
